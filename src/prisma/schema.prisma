generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id           String   @id @default(cuid())
  studentName  String
  studentAge   Int
  projectName  String
  description  String   @default("")
  sdgGoal      String?
  currentPhase Int      @default(1)
  currentStep  Int      @default(1)
  status       String   @default("active")
  coachNotes   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  phaseOutputs PhaseOutput[]
  chats        ChatMessage[]
}

model PhaseOutput {
  id          String   @id @default(cuid())
  projectId   String
  phase       Int
  step        Int
  outputType  String
  content     String
  aiRoleUsed  String
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id        String   @id @default(cuid())
  projectId String
  phase     Int
  step      Int
  role      String
  aiRole    String?
  content   String
  metadata  String?
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
